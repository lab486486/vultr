---
import '../styles/global.css';
import { site, mediaOrigin } from '../site.config';
import adsenseHead from '../data/adsense/head-script.json';
import gsc from '../data/site/google-search-console.json';
import analytics from '../data/site/analytics.json';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = site.description,
  canonical,
  ogImage,
} = Astro.props;

const pageUrl = canonical || new URL(Astro.url.pathname, site.baseUrl).toString();
const fullTitle = title === site.name || title === site.title ? site.title : `${title} | ${site.title}`;
const pathname = Astro.url.pathname;
const r2Origin = mediaOrigin();

const navItems = [
  { href: '/compare/', label: '호스팅 비교', active: pathname.startsWith('/compare') },
  { href: '/guides/', label: '가이드', active: pathname.startsWith('/guides') },
  { href: '/start/', label: '시작하기', active: pathname.startsWith('/start') },
];
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="ko_KR" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+KR:wght@400;600;700&family=Syne:wght@700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+KR:wght@400;600;700&family=Syne:wght@700;800&display=swap"
      />
    </noscript>
    {
      ogImage && r2Origin && ogImage.startsWith(r2Origin) && (
        <link rel="preconnect" href={r2Origin} crossorigin />
      )
    }
    {gsc.code && <Fragment set:html={gsc.code.includes('<meta') ? gsc.code : `<meta name="google-site-verification" content="${gsc.code}" />`} />}
    {adsenseHead.script && <Fragment set:html={adsenseHead.script} />}
    {analytics.code && <Fragment set:html={analytics.code} />}
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">V&#8209;<span>press</span></a>

        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-menu"
          aria-label="메뉴 열기"
        >
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>

        <nav class="site-nav" id="site-menu" aria-label="주요 메뉴" hidden>
          <ul class="nav-links">
            {
              navItems.map((item) => (
                <li>
                  <a href={item.href} aria-current={item.active ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          © {new Date().getFullYear()}
          <a href="/about/">{site.copyrightName}</a>
          · vultr.seoul.kr
        </p>
        <p class="disclaimer">
          이 사이트는 Vultr, Chemicloud, Cloudways 등 언급된 업체의 공식 사이트가 아닙니다.
          상표는 각 소유자에게 있으며, 리뷰·비교 목적의 정보 제공과 어필리에이트 링크가 포함될 수
          있습니다.
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle');
      const menu = document.querySelector('#site-menu');
      if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement) {
        const setOpen = (open) => {
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
          toggle.classList.toggle('is-open', open);
          menu.hidden = !open;
          document.body.classList.toggle('nav-open', open);
        };

        toggle.addEventListener('click', () => {
          setOpen(toggle.getAttribute('aria-expanded') !== 'true');
        });

        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => setOpen(false));
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      }
    </script>
  </body>
</html>
